# Non-secret addresses and protected-file locations only. Never put credential values here.
AKV_DATABASE_DSN_FILE=/run/akv/control/database-dsn
AKV_CONTROL_LISTEN_ADDRESS=127.0.0.1:8080
AKV_CONTROL_PUBLIC_ORIGIN=http://127.0.0.1:8080
AKV_CONTROL_COOKIE_SECURE=false
AKV_OPENBAO_CONTROL_ADDRESS=http://127.0.0.1:8200
AKV_OPENBAO_CONTROL_TOKEN_FILE=/run/akv/control/openbao-token

AKV_EXECUTION_LISTEN_ADDRESS=127.0.0.1:8081
AKV_OPENBAO_ADDRESS=http://127.0.0.1:8200
AKV_OPENBAO_TOKEN_FILE=/run/akv/execution/openbao-token

AKV_CONTROL_URL=http://127.0.0.1:8080
AKV_EXECUTION_URL=http://127.0.0.1:8081
AKV_AGENT_TOKEN_FILE=/run/akv/agent/token
